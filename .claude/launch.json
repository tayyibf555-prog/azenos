{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@azen/web", "dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "web-turbo",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@azen/web", "exec", "next", "dev", "--turbopack"],
      "port": 3000,
      "autoPort": true
    }
  ]
}
