# ── Database ────────────────────────────────────────────────────────────────
# Local dev (pnpm db:local — native Postgres on 127.0.0.1:54329).
# Production RUNTIME uses the Supabase TRANSACTION pooler (port 6543) —
# serverless-safe; packages/db/src/client.ts disables prepared statements on
# 6543 automatically. Migrations are the exception: `pnpm db:migrate` must use
# the SESSION pooler (port 5432) or a direct connection — drizzle.config.ts
# refuses to run against 6543.
DATABASE_URL=postgres://postgres:postgres@localhost:54329/azen_os
# Read-only role — Ask Azen run_sql (§9.8) only. Created by migration 0001.
DATABASE_URL_RO=postgres://azen_readonly:readonly@localhost:54329/azen_os

# ── Supabase (hosted project — fill in once created) ───────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── AI ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
# Model IDs are pinned in packages/config/src/index.ts (AGENT_MODEL, CHAT_MODEL)
# and can be overridden here per environment.
AGENT_MODEL=
CHAT_MODEL=
VOYAGE_API_KEY=
EMBEDDING_MODEL=
EMBEDDING_DIMS=1024
AGENT_BUDGET_PENCE_MONTHLY=10000

# ── Jobs ────────────────────────────────────────────────────────────────────
TRIGGER_SECRET_KEY=

# ── Delivery ────────────────────────────────────────────────────────────────
RESEND_API_KEY=
BRIEF_FROM_EMAIL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
OWNER_WHATSAPP_TO=

# ── Rate limiting / queues ──────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Native integrations ─────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
CALENDLY_WEBHOOK_SIGNING_KEY=
CALENDLY_PAT=

# ── App ─────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
INGEST_SIGNING_VERSION=v1

# ── Ingest key encryption ───────────────────────────────────────────────────
# 32 bytes base64 — generate with: openssl rand -base64 32
INGEST_SECRET_ENC_KEY=

# ── OpenAI (Whisper voice dictation in the intake co-pilot) ─────────────────
OPENAI_API_KEY=
